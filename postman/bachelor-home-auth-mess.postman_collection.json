            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Join Flow User\",\n  \"phoneNumber\": \"{{memberPhone}}\",\n  \"email\": \"{{memberEmail}}\",\n  \"gender\": \"FEMALE\",\n  \"password\": \"{{password}}\",\n  \"referelCode\": \"REF999\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
