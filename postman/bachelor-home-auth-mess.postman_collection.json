            },
            "url": {
              "raw": "{{baseUrl}}/users/{{targetUserId}}",
              "host": ["{{baseUrl}}"],
              "path": ["users", "{{targetUserId}}"]
            }
          }
        },
        {
          "name": "Admin Delete User",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
