        {
          "name": "Google Social Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idToken\": \"{{googleIdToken}}\",\n  \"googleId\": \"{{googleUserId}}\",\n  \"email\": \"{{googleEmail}}\",\n  \"fullName\": \"Google User\",\n  \"phoneNumber\": \"{{phoneNumber}}\",\n  \"gender\": \"OTHER\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/social/google",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "social", "google"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Capture Google login tokens and user id', function () {",
                  "  const json = pm.response.json();",
                  "  if (json?.data?.tokens?.accessToken) {",
                  "    pm.collectionVariables.set('accessToken', json.data.tokens.accessToken);",
                  "  }",
                  "  if (json?.data?.tokens?.refreshToken) {",
                  "    pm.collectionVariables.set('refreshToken', json.data.tokens.refreshToken);",
                  "  }",
                  "  if (json?.data?.user?.id) {",
                  "    pm.collectionVariables.set('userId', json.data.user.id);",
                  "  }",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Onboarding Status",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/onboarding-status",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "onboarding-status"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Onboarding status is fetched successfully', function () {",
                  "  pm.expect(pm.response.code).to.eql(200);",
                  "  const json = pm.response.json();",
                  "  if (json?.data?.status) {",
                  "    pm.collectionVariables.set('onboardingStatus', json.data.status);",
                  "  }",
                  "  if (json?.data?.role) {",
                  "    pm.collectionVariables.set('userRole', json.data.role);",
                  "  }",
                  "});"
                ]
              }
            }
          ]
        }
