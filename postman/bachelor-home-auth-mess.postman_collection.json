  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register User For Create Flow",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Create Flow User\",\n  \"phoneNumber\": \"{{managerPhone}}\",\n  \"email\": \"{{managerEmail}}\",\n  \"gender\": \"MALE\",\n  \"password\": \"{{password}}\",\n  \"referralCode\": \"REF123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201 or 200', function () {",
                  "  pm.expect([200, 201]).to.include(pm.response.code);",
                  "});",
                  "pm.test('Store create-flow credentials for OTP and login', function () {",
                  "  pm.collectionVariables.set('phoneNumber', pm.collectionVariables.get('managerPhone'));",
                  "  pm.collectionVariables.set('identifier', pm.collectionVariables.get('managerEmail'));",
                  "});",
                  "pm.test('Capture dev OTP if present', function () {",
                  "  const json = pm.response.json();",
                  "  if (json?.data?.otp) {",
                  "    pm.collectionVariables.set('otp', json.data.otp);",
                  "  }",
                  "});"
                ]
              }
            }
          ]
        },
        {
