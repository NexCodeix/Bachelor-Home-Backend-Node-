{
  "info": {
    "_postman_id": "f3dcf20a-4874-4bcc-9948-0e4f12b8396e",
    "name": "Bachelor Home API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Auth + OTP + social login + mess onboarding collection for NestJS backend."
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Manager",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Manager One\",\n  \"phoneNumber\": \"{{managerPhone}}\",\n  \"email\": \"{{managerEmail}}\",\n  \"gender\": \"MALE\",\n  \"password\": \"{{password}}\",\n  \"role\": \"MANAGER\",\n  \"referralCode\": \"REF123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201 or 200', function () {",
                  "  pm.expect([200, 201]).to.include(pm.response.code);",
                  "});",
                  "pm.test('Capture dev OTP if present', function () {",
                  "  const json = pm.response.json();",
                  "  if (json?.data?.otp) {",
                  "    pm.collectionVariables.set('otp', json.data.otp);",
                  "  }",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Register Member",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Member One\",\n  \"phoneNumber\": \"{{memberPhone}}\",\n  \"email\": \"{{memberEmail}}\",\n  \"gender\": \"FEMALE\",\n  \"password\": \"{{password}}\",\n  \"role\": \"MEMBER\",\n  \"referelCode\": \"REF999\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            }
          }
        },
        {
          "name": "Send OTP",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phoneNumber\": \"{{phoneNumber}}\",\n  \"purpose\": \"REGISTER\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/otp/send",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "otp",
                "send"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Capture OTP if returned in dev', function () {",
                  "  const json = pm.response.json();",
                  "  if (json?.data?.otp) {",
                  "    pm.collectionVariables.set('otp', json.data.otp);",
                  "  }",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Verify OTP",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phoneNumber\": \"{{phoneNumber}}\",\n  \"purpose\": \"REGISTER\",\n  \"otp\": \"{{otp}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/otp/verify",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "otp",
                "verify"
              ]
            }
          }
        },
        {
          "name": "Login (email or phone as identifier)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identifier\": \"{{identifier}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Capture access/refresh tokens', function () {",
                  "  const json = pm.response.json();",
                  "  const access = json?.data?.tokens?.accessToken;",
                  "  const refresh = json?.data?.tokens?.refreshToken;",
                  "  if (access) pm.collectionVariables.set('accessToken', access);",
                  "  if (refresh) pm.collectionVariables.set('refreshToken', refresh);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Forgot Password - Request OTP",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phoneNumber\": \"{{phoneNumber}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/forgot-password/request",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "forgot-password",
                "request"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json?.data?.otp) {",
                  "  pm.collectionVariables.set('otp', json.data.otp);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Forgot Password - Verify OTP",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phoneNumber\": \"{{phoneNumber}}\",\n  \"purpose\": \"FORGOT_PASSWORD\",\n  \"otp\": \"{{otp}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/otp/verify",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "otp",
                "verify"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json?.data?.resetToken) {",
                  "  pm.collectionVariables.set('resetToken', json.data.resetToken);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Forgot Password - Reset",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phoneNumber\": \"{{phoneNumber}}\",\n  \"resetToken\": \"{{resetToken}}\",\n  \"newPassword\": \"{{newPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/forgot-password/reset",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "forgot-password",
                "reset"
              ]
            }
          }
        },
        {
          "name": "Google Social Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idToken\": \"{{googleIdToken}}\",\n  \"googleId\": \"{{googleUserId}}\",\n  \"email\": \"{{googleEmail}}\",\n  \"fullName\": \"Google User\",\n  \"phoneNumber\": \"{{phoneNumber}}\",\n  \"role\": \"MEMBER\",\n  \"gender\": \"OTHER\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/social/google",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "social",
                "google"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json?.data?.tokens?.accessToken) {",
                  "  pm.collectionVariables.set('accessToken', json.data.tokens.accessToken);",
                  "}",
                  "if (json?.data?.tokens?.refreshToken) {",
                  "  pm.collectionVariables.set('refreshToken', json.data.tokens.refreshToken);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Onboarding Status",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/onboarding-status",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "onboarding-status"
              ]
            }
          }
        }
      ]
    },
