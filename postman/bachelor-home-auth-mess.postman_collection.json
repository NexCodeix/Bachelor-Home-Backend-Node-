    {
      "name": "Users",
      "item": [
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/users/me",
              "host": ["{{baseUrl}}"],
              "path": ["users", "me"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('My profile is fetched successfully', function () {",
                  "  pm.expect(pm.response.code).to.eql(200);",
                  "  const json = pm.response.json();",
                  "  if (json?.data?.id) {",
                  "    pm.collectionVariables.set('userId', json.data.id);",
                  "  }",
                  "  if (json?.data?.role) {",
                  "    pm.collectionVariables.set('userRole', json.data.role);",
                  "  }",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Update My Profile",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "fullName",
                  "value": "{{updateFullName}}",
                  "type": "text"
                },
                {
                  "key": "email",
                  "value": "{{updateEmail}}",
                  "type": "text"
                },
                {
                  "key": "phoneNumber",
                  "value": "{{updatePhoneNumber}}",
                  "type": "text"
                },
                {
                  "key": "gender",
                  "value": "OTHER",
                  "type": "text"
                },
                {
                  "key": "profileImage",
                  "type": "file",
                  "src": "{{profileImagePath}}"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/users/me",
              "host": ["{{baseUrl}}"],
              "path": ["users", "me"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('My profile is updated successfully', function () {",
                  "  pm.expect(pm.response.code).to.eql(200);",
                  "  const json = pm.response.json();",
                  "  if (json?.data?.profileImageUrl) {",
                  "    pm.collectionVariables.set('profileImageUrl', json.data.profileImageUrl);",
                  "  }",
                  "});"
                ]
              }
            }
          ]
        },
