          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201 or 200', function () {",
                  "  pm.expect([200, 201]).to.include(pm.response.code);",
                  "});",
                  "pm.test('Store join-flow credentials for OTP and login', function () {",
                  "  pm.collectionVariables.set('phoneNumber', pm.collectionVariables.get('memberPhone'));",
