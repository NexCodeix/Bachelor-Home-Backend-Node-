generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  UNASSIGNED
  MANAGER
  MEMBER
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum OtpPurpose {
  REGISTER
  FORGOT_PASSWORD
}

enum OtpChannel {
  PHONE
}

enum MessMembershipRole {
  OWNER
  MEMBER
}

enum MessJoinRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum MealType {
  BREAKFAST
  LUNCH
  DINNER
}

enum MealRequestType {
  MEAL_ON
  MEAL_OFF
  GUEST_MEAL
}

enum MealRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum AttendanceStatus {
  NOT_MARKED
  GOT_MEAL
  DID_NOT_GET
}

enum ExpenseStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ExpenseMoneySource {
  MESS_FUND
  SELF_FUND
}

model User {
  id               String       @id @default(uuid())
  fullName         String
  phoneNumber      String?      @unique
  email            String?      @unique
  profileImageUrl  String?
  gender           Gender
  passwordHash     String?
  referralCode     String?
  role             Role
  isSocial         Boolean      @default(false)
  isPhoneVerified  Boolean      @default(false)
  isActive         Boolean      @default(true)
  googleId         String?      @unique
  refreshTokenHash String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  otpCodes         OtpCode[]
  ownedMess        Mess?
  memberships      MessMember[]
}

model OtpCode {
  id          String     @id @default(uuid())
  userId      String?
  phoneNumber String
  purpose     OtpPurpose
  channel     OtpChannel @default(PHONE)
  codeHash    String
  expiresAt   DateTime
  attemptCount Int       @default(0)
  maxAttempts Int
  consumedAt  DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  user User? @relation(fields: [userId], references: [id])

  @@index([phoneNumber, purpose])
}

model Mess {
  id               String       @id @default(uuid())
  name             String
  ownerUserId      String       @unique
  ownerPhoneNumber String
  district         String
  subDistrict      String
  thana            String
  fullAddress      String
  capacity         Int
  inviteCode       String       @unique
  isJoinEnabled    Boolean      @default(true)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  owner    User        @relation(fields: [ownerUserId], references: [id])
  members  MessMember[]
  mealMenus MessMealMenu[]
  mealRoutines MessMealRoutine[]
  mealDays  MealDay[]
  mealRequests MealRequest[]
  expenses Expense[]
}

model MessMember {
  id        String             @id @default(uuid())
  messId    String
  userId    String
  role      MessMembershipRole @default(MEMBER)
  requestStatus MessJoinRequestStatus @default(APPROVED)
  respondedAt DateTime?
  joinedAt  DateTime           @default(now())

  mess Mess @relation(fields: [messId], references: [id])
  user User @relation(fields: [userId], references: [id])
  mealRoutines MemberMealRoutine[]
  mealStatuses MealDayMemberStatus[]
  mealRequests MealRequest[]
  expenses Expense[]

  @@unique([messId, userId])
  @@index([userId])
  @@index([messId, requestStatus])
}

model MessMealMenu {
  id          String   @id @default(uuid())
  messId      String
  year        Int
  month       Int
  mealType    MealType
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  mess Mess @relation(fields: [messId], references: [id])

  @@unique([messId, year, month, mealType])
  @@index([messId, year, month])
}

model MessMealRoutine {
  id        String   @id @default(uuid())
  messId    String
  weekday   Int
  mealType  MealType
  isEnabled Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  mess Mess @relation(fields: [messId], references: [id])

  @@unique([messId, weekday, mealType])
  @@index([messId])
}

model MemberMealRoutine {
  id           String   @id @default(uuid())
  messMemberId String
  weekday      Int
  mealType     MealType
  isEnabled    Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  messMember MessMember @relation(fields: [messMemberId], references: [id])

  @@unique([messMemberId, weekday, mealType])
  @@index([messMemberId])
}

model MealDay {
  id              String   @id @default(uuid())
  messId          String
  date            DateTime
  year            Int
  month           Int
  day             Int
  weekday         Int
  mealType        MealType
  menuDescription String?
  isEnabled       Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  mess Mess @relation(fields: [messId], references: [id])
  memberStatuses MealDayMemberStatus[]
  requests MealRequest[]

  @@unique([messId, date, mealType])
  @@index([messId, year, month])
  @@index([messId, date])
}

model MealDayMemberStatus {
  id               String           @id @default(uuid())
  mealDayId        String
  messMemberId     String
  isEnabled        Boolean          @default(true)
  guestCount       Int              @default(0)
  isOverridden     Boolean          @default(false)
  attendanceStatus AttendanceStatus @default(NOT_MARKED)
  attendanceMarkedAt DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  mealDay MealDay @relation(fields: [mealDayId], references: [id])
  messMember MessMember @relation(fields: [messMemberId], references: [id])

  @@unique([mealDayId, messMemberId])
  @@index([messMemberId])
  @@index([mealDayId])
  @@index([messMemberId, attendanceStatus])
}

model MealRequest {
  id            String            @id @default(uuid())
  messId        String
  mealDayId     String
  messMemberId  String
  requestType   MealRequestType
  status        MealRequestStatus @default(PENDING)
  guestCount    Int               @default(0)
  reason        String?
  managerNote   String?
  respondedAt   DateTime?
  cancelledAt   DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  mess Mess @relation(fields: [messId], references: [id])
  mealDay MealDay @relation(fields: [mealDayId], references: [id])
  messMember MessMember @relation(fields: [messMemberId], references: [id])

  @@index([messId, status])
  @@index([messMemberId, status])
  @@index([mealDayId])
  @@index([createdAt])
}

model Expense {
  id                     String            @id @default(uuid())
  messId                 String
  messMemberId           String
  dateTime               DateTime
  year                   Int
  month                  Int
  category               String
  itemName               String
  amountValue            Decimal           @db.Decimal(12, 2)
  amountUnitName         String?
  perAmountValue         Decimal?          @db.Decimal(12, 2)
  voucherImageUrl        String?
  totalValue             Decimal           @db.Decimal(12, 2)
  moneySource            ExpenseMoneySource?
  receivedMessFundAmount Decimal?          @db.Decimal(12, 2)
  returnAmount           Decimal?          @db.Decimal(12, 2)
  status                 ExpenseStatus     @default(PENDING)
  rejectionReason        String?
  respondedAt            DateTime?
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt

  mess       Mess       @relation(fields: [messId], references: [id])
  messMember MessMember @relation(fields: [messMemberId], references: [id])

  @@index([messId, year, month])
  @@index([messId, status])
  @@index([messMemberId, status])
  @@index([messId, category])
  @@index([createdAt])
}
